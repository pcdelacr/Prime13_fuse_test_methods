<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>MPE.MIT.ATE_TM.PrimePHGenerator</id>
    <version>3.8.4</version>
    <title>PrimePHGenerator</title>
    <authors>MPE.MIT.ATE.TM</authors>
    <owners>MPE.MIT.ATE.TM</owners>
