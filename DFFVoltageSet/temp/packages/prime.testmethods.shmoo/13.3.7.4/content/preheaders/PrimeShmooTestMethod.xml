        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="YAxisParamType" descriptions="YAxis parameter type. None by Default.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>LevelsTestCondition</Choice>
          <Choice>None</Choice>
          <Choice>PatConfig</Choice>
          <Choice>PatConfigSetPoint</Choice>
          <Choice>TimingTestCondition</Choice>
          <Choice>UserDefined</Choice>
          <Choice>VoltageConfig</Choice>
        </Choices>
        <Default>None</Default>
        <Optional />
