      <Parameter name="YAxisRange" descriptions="The YAxisRange. Default format: \&quot;Start: Resolution: NumberOfPoints\&quot;.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="YAxisDatalogPrefix" descriptions="The prefix for scaling the Y axis. (Base, Milli, Micro, Nano).">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Base</Choice>
          <Choice>Micro</Choice>
          <Choice>Milli</Choice>
          <Choice>Nano</Choice>
        </Choices>
        <Default>Base</Default>
        <Optional />
      </Parameter>
      <Parameter name="YAxisDatalogName" descriptions="The name used during datalog prints for Y Axis. Uses YAxisParam by default.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
