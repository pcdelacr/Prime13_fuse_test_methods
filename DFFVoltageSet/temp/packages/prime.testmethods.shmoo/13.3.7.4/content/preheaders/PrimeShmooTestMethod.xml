        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="PrintFormat" descriptions="The print format for shmoo ituffs.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>ShmooHub</Choice>
          <Choice>ARIES</Choice>
          <Choice>ECADS</Choice>
        </Choices>
        <Default>ShmooHub</Default>
        <Optional />
      </Parameter>
      <Parameter name="PowerDownBetweenPoints" descriptions="Power down between point. This will trigger EndSequence before ApplyTestCondition in PrePointExecute.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>DISABLED</Choice>
          <Choice>ENABLED</Choice>
        </Choices>
        <Default>DISABLED</Default>
        <Optional />
      </Parameter>
      <Parameter name="PlotMode" descriptions="PlotMode.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>NORMAL</Choice>
          <Choice>CUSTOM</Choice>
        </Choices>
        <Default>NORMAL</Default>
        <Optional />
