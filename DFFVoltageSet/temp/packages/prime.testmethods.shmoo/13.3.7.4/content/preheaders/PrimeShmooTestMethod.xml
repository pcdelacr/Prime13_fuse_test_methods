        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Base</Choice>
          <Choice>Micro</Choice>
          <Choice>Milli</Choice>
          <Choice>Nano</Choice>
        </Choices>
        <Default>Base</Default>
        <Optional />
      </Parameter>
      <Parameter name="XAxisDatalogName" descriptions="The name used during datalog prints for X axis. Uses XAxisParam by default.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
