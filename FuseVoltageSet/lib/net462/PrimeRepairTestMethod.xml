<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimeRepairTestMethod" MetaData="dll=Prime.TestMethods.Array" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeRepairTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="ResourceFile" descriptions="Path to the Resource input file.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>File</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="ArrayFile" descriptions="Path to the Array input file.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>File</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="TargetArray" descriptions="Array name that the instance will use for data processing.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="LyaStorageTag" descriptions="Specific tag to create a unique shared storage name for the current repair instance. This will later be used to share repair data with the corresponding LYA test instance.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="DecoderMatchLabel" descriptions="Label from which to obtain the decoding parameters to be used from the array file.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="DataLog" descriptions="Selects the output type in which to log the instance results.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>ItuffOnly</Choice>
          <Choice>TFile</Choice>
          <Choice>RFileRaw</Choice>
          <Choice>RFileReduced</Choice>
          <Choice>Lya</Choice>
        </Choices>
        <Default>ItuffOnly</Default>
        <Optional />
      </Parameter>
      <Parameter name="LyaCellSelection" descriptions="LYA cell select algorithm.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>FirstCell</Choice>
          <Choice>LastCell</Choice>
        </Choices>
        <Default>FirstCell</Default>
        <Optional />
      </Parameter>
      <Parameter name="OperationMode" descriptions="Operation mode.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Repair</Choice>
          <Choice>Raster</Choice>
        </Choices>
        <Default>Repair</Default>
        <Optional />
      </Parameter>
      <Parameter name="AlgorithmPriority" descriptions="Prioritization of the repair algorithm criteria.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Default</Choice>
          <Choice>NoSpares</Choice>
          <Choice>ResourceOnly</Choice>
        </Choices>
        <Default>Default</Default>
        <Optional />
      </Parameter>
      <Parameter name="BaseNumber" descriptions="BaseNumber for R-file printing.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="InputStorageKey" descriptions="SharedStorage input key in DUT context to be grabbed from list of strings table.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="DeleteInputStorage" descriptions="Defines whether to delete input stored data if input is provided through a storage key.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Enabled</Choice>
          <Choice>Disabled</Choice>
        </Choices>
        <Default>Disabled</Default>
        <Optional />
      </Parameter>
      <Parameter name="InputForDebug" descriptions="Input data for testing.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
    </Parameters>
    <ExitPorts>
      <ExitPort>
        <PortNumber>4</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PASS PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>3</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PASS PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>2</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PASS PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>1</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PASS PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>0</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>FAIL PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-1</PortNumber>
        <PortType>Error</PortType>
        <PortDescriptions>PORT FAIL FOR SW ERROR CONDITION</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-2</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PORT FAIL FOR HW ALARM CONDITION</PortDescriptions>
      </ExitPort>
    </ExitPorts>
  </TestLibrary>
</TestLibraryInterfaces>