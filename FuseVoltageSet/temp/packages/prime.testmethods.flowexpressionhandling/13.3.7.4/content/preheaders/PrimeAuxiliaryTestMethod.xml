<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimeAuxiliaryTestMethod" MetaData="dll=Prime.TestMethods.FlowExpressionHandling" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeAuxiliaryTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="Expression" descriptions="Gets or sets the name of the callback to execute.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="DataType" descriptions="Gets or sets the parameters to send to the callback.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Integer</Choice>
          <Choice>Double</Choice>
          <Choice>String</Choice>
        </Choices>
        <Default>Integer</Default>
        <Optional />
      </Parameter>
      <Parameter name="Storage" descriptions="Gets or sets the ResultToken storage type.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>SharedStorage</Choice>
          <Choice>DFF</Choice>
          <Choice>UserVar</Choice>
        </Choices>
        <Default>SharedStorage</Default>
        <Optional />
      </Parameter>
      <Parameter name="Datalog" descriptions="Gets or sets datalog enable type.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Disabled</Choice>
          <Choice>Enabled</Choice>
        </Choices>
        <Default>Disabled</Default>
        <Optional />
      </Parameter>
      <Parameter name="ResultToken" descriptions="Gets or sets the names of token where the evaluated result will be set.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="ResultPort" descriptions="Gets or sets an expression to set exit port based on result.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
    </Parameters>
    <ExitPorts>
      <ExitPort>
        <PortNumber>0</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PORT FAIL</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>1</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PORT PASS</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>2-23</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PORT REDIRECTED BY EXPRESSIONS</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-1</PortNumber>
        <PortType>Error</PortType>
        <PortDescriptions>PORT FAIL FOR SW ERROR CONDITION</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-2</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PORT FAIL FOR HW ALARM CONDITION</PortDescriptions>
      </ExitPort>
    </ExitPorts>
  </TestLibrary>
</TestLibraryInterfaces>