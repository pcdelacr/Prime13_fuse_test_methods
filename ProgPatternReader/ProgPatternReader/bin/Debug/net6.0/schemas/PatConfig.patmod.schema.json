{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "Configurations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/Configuration" }
    }
  },
  "required": [
    "Configurations"
  ],
  "definitions": {
    "Configuration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Name": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "PatternsRegEx": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/definitions/nonEmptyString"
          }
        },
        "Storable": {
          "type": "boolean",
        },
        "ConfigurationElement": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/ConfigurationElement" }
        }
      },
      "required": [
        "Name",
        "ConfigurationElement"
      ]
    },
    "ConfigurationElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Name": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "Type": {
          "type": "string",
          "enum": ["PINDATA", "INSTRUCTION", "MTV", "CTV", "LRPT"]
        },
        "IsChannelLink": {
          "type": "boolean"
        },
        "Pin": {
          "type": ["array"],
          "minLength": 1,
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/nonEmptyString"
          }
        },
        "Domain": {
          "type": ["array"],
          "minLength": 1,
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/nonEmptyString"
          }
        },
        "StartAddress": {
          "type": ["array"],
          "minLength": 1,
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/nonEmptyString"
          }
        },
        "StartAddressOffset": {
          "type": ["array"],
          "minItems": 1,
          "items": {
            "type": "integer"
          }
        },
        "EndAddress": {
          "type": ["array"],
          "minLength": 1,
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/nonEmptyString"
          }
        },
        "EndAddressOffset": {
          "type": ["array"],
          "minItems": 1,
          "items": {
            "type": "integer"
          }
        },
        "Ratio": {
          "type": "integer",
          "minimum": 1
        },
        "PatternsRegEx": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/definitions/nonEmptyString"
          }
        },
        "Plists": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/definitions/nonEmptyString"
          }
        },
        "Data": {
          "$ref": "#/definitions/nonEmptyString"
        },
		"ValidationMode": {
			"type": "string"
        }
      },
      "required": [
        "Type",
        "StartAddress",
        "StartAddressOffset",
        "EndAddress",
        "EndAddressOffset"
      ],
      "oneOf": [
        { "required": ["Pin"] },
        { "required": ["Domain"] }
      ]
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    }
  }
}