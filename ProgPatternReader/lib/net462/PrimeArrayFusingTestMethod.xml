<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimeArrayFusingTestMethod" MetaData="dll=Prime.TestMethods.Array" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeArrayFusingTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="Patlist" descriptions="Gets or sets Patlist name for setting up the fuse handles.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>Plist</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="DffUploadMode" descriptions="Gets or sets FuseToDFFWritingMode.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>ENABLED</Choice>
          <Choice>DISABLED</Choice>
        </Choices>
        <Default>ENABLED</Default>
        <Optional />
      </Parameter>
      <Parameter name="FusingMode" descriptions="Gets or sets FusingMode.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>IMPORT_SOLUTION_FROM_ARRAYREPAIR_AND_APPLY</Choice>
          <Choice>IMPORT_SOLUTION_FROM_DFF_AND_APPLY</Choice>
          <Choice>IMPORT_SOLUTION_FROM_STORAGE_DFF_AND_APPLY</Choice>
          <Choice>RESET_ALL_RESOURCES</Choice>
        </Choices>
        <Default>RESET_ALL_RESOURCES</Default>
        <Optional />
      </Parameter>
      <Parameter name="FuseResourceFile" descriptions="Gets or sets FuseResourceFile input file.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>File</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
    </Parameters>
    <ExitPorts>
      <ExitPort>
        <PortNumber>1</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PASS PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>0</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>FAIL PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-1</PortNumber>
        <PortType>Error</PortType>
        <PortDescriptions>PORT FAIL FOR SW ERROR CONDITION</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-2</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PORT FAIL FOR HW ALARM CONDITION</PortDescriptions>
      </ExitPort>
    </ExitPorts>
  </TestLibrary>
</TestLibraryInterfaces>