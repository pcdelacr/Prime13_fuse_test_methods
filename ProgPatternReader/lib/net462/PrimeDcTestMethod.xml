      </Parameter>
      <Parameter name="DatalogLevel" descriptions="Datalog level(ALL, FAIL_ONLY, COMPRESS, PINMAP_COMPRESS, PIN_DETAIL\&quot;).">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>ALL</Choice>
          <Choice>FAIL_ONLY</Choice>
          <Choice>COMPRESS</Choice>
          <Choice>PINMAP_COMPRESS</Choice>
          <Choice>PIN_DETAIL</Choice>
        </Choices>
        <Default>FAIL_ONLY</Default>
        <Optional />
      </Parameter>
      <Parameter name="LowLimits" descriptions="Comma separated low limits for the measure Pins.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="HighLimits" descriptions="Comma separated high limits for the measure Pins.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="IfeObject" descriptions="Gets or sets the IFE object of type IDcExtensions.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="SamplingCount" descriptions="Sampling count per pin. Optional field , Required when measuring the same pin few times.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="EnableFlushSmartTc" descriptions="Flag to enable flushing Levels Smart TC.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Enabled</Choice>
          <Choice>Disabled</Choice>
        </Choices>
        <Default>Enabled</Default>
        <Optional />
      </Parameter>
      <Parameter name="DFFEnabled" descriptions="Gets or sets if DFFing the value to SCEDM or not. Default is Disabled.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Enabled</Choice>
          <Choice>Disabled</Choice>
        </Choices>
        <Default>Disabled</Default>
        <Optional />
      </Parameter>
      <Parameter name="EDMEnabled" descriptions="Gets or sets if Print Measurements to Ituff or not. Default is Disabled.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Enabled</Choice>
          <Choice>Disabled</Choice>
        </Choices>
        <Default>Disabled</Default>
        <Optional />
      </Parameter>
      <Parameter name="DFFNAME" descriptions="Gets or sets if DFFing the value to SCEDM or not. Default to SCEDM.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default>SCEDM</Default>
        <Optional />
      </Parameter>
      <Parameter name="PinToDff" descriptions="Assign pin name to overwrite default - default is first index of Pins list">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
