          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="ResultPort" descriptions="Gets or sets an expression to set exit port based on the callback return value.">
