      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeRunCallbackTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="Callback" descriptions="Gets or sets the name of the callback to execute.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
