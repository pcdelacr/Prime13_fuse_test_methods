<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimeLyaTestMethod" MetaData="dll=Prime.TestMethods.Array" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeLyaTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="TimingsTc" descriptions="TimingsTc for plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>TimingCondition</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="LevelsTc" descriptions="LevelsTc for plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>LevelsCondition</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="LyaConfigFile" descriptions="LYA configuration file full path.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>File</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="BitLinePin" descriptions="Name of the pin which acts as Bit Line.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="BitLineBarPin" descriptions="Name of the pin which acts as Bit Line Bar.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="VccPin" descriptions="VCC pin to base the high force level on.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="VccMaxLevel" descriptions="Max value to set the high force level on.">
        <Type>
          <Tester>Double</Tester>
          <TestProgram>Double</TestProgram>
        </Type>
        <Default>-555.5</Default>
        <Optional />
      </Parameter>
      <Parameter name="PrePause" descriptions="Gets or sets Pre-Measurement delay specified in Seconds.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="BaseNumber" descriptions="Array Base Number to be used with raster data (FA/FI). Changing numbers directly controls the RASTER HEADER.">
        <Type>
          <Tester>Integer</Tester>
          <TestProgram>Integer</TestProgram>
        </Type>
        <Default>0</Default>
        <Optional />
      </Parameter>
      <Parameter name="MeasurementThreshold" descriptions="Threshold value that defines a range from its negative to positive value, this will be used to determine if DC measurements are valid or not.">
        <Type>
          <Tester>Integer</Tester>
          <TestProgram>Integer</TestProgram>
        </Type>
        <Default>0</Default>
        <Optional />
      </Parameter>
      <Parameter name="TargetArray" descriptions="JSON configuration set name.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="StorageTag" descriptions="Specific tag to obtain the unique shared storage name associated to the corresponding repair instance.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="ExecutionMode" descriptions="LYA execution mode.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Manual</Choice>
          <Choice>Manufacturing</Choice>
          <Choice>GoodCell</Choice>
        </Choices>
        <Default>Manufacturing</Default>
        <Optional />
      </Parameter>
      <Parameter name="MaxLyaCount" descriptions="Maximum LYA Tests Per instance (max. cells to test).">
        <Type>
          <Tester>Integer</Tester>
          <TestProgram>Integer</TestProgram>
        </Type>
        <Default>99999</Default>
        <Optional />
      </Parameter>
    </Parameters>
    <ExitPorts>
      <ExitPort>
        <PortNumber>3</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>INVALID MEASUREMENTS PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>2</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>MAX FAIL COUNT EXCEEDED PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>1</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PASS PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>0</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>FAIL PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-1</PortNumber>
        <PortType>Error</PortType>
        <PortDescriptions>PORT FAIL FOR SW ERROR CONDITION</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-2</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PORT FAIL FOR HW ALARM CONDITION</PortDescriptions>
      </ExitPort>
    </ExitPorts>
  </TestLibrary>
</TestLibraryInterfaces>