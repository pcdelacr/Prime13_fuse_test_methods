          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="DieId" descriptions="Die Id for the token to be set to. &quot; +&#xD;&#xA;                     &quot;Only single die id is accepted. If it's empty, it will set the token to the current die id.">
