Version 0.1.0;
FormatMap TelemetryEventFormatMap  #Conventional datalog format
{
	Type Telemetry; #Name of the stream in your DatalogTypeDef.xml
	Event TelemetryEvent;  #Name of the event in your DatalogTypeDef.xml
	Format TelemetryEventFormat; #Name of the format (used in your Format.dfs file)
}
FormatMap TelemetryEndOfTransmissionFormatMap
{
	Type Telemetry;
	Event HMI_EndOfTransmission;
	Format TelemetryEndOfTransmissionFormat;
}