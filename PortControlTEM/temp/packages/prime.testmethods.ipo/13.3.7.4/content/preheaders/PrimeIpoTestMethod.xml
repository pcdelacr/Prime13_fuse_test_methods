<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimeIpoTestMethod" MetaData="dll=Prime.TestMethods.Ipo" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeIpoTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="ConfigurationFile" descriptions="ConfigurationFile. Can be use with variable ~HDMT_TPL_DIR.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>File</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="RestoreMode" descriptions="Default is set to Disabled. When is Enabled - Restore modified parameter to initial/snapshot value before Ipo execute.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Enabled</Choice>
          <Choice>Disabled</Choice>
        </Choices>
        <Default>Disabled</Default>
        <Optional />
      </Parameter>
      <Parameter name="ExecutionMode" descriptions="Default ExecuteAll. Supported Mode ExecuteAll - Run all test. FirstFail - Run all test, exit at first fail test. FirstPass - Run all test, exit at first pass test. FirstAllInstancePass - Run all test, exit when all test pass. FirstAllInstanceFail - Run all test, exit when all test fail.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>ExecuteAll</Choice>
          <Choice>FirstFail</Choice>
          <Choice>FirstPass</Choice>
          <Choice>FirstAllInstancePass</Choice>
          <Choice>FirstAllInstanceFail</Choice>
        </Choices>
        <Default>ExecuteAll</Default>
        <Optional />
      </Parameter>
    </Parameters>
    <ExitPorts>
      <ExitPort>
        <PortNumber>2</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PASS PORT, IPO ExecuteMode condition met.</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>1</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PASS PORT, IPO sucessfully execute all iteration but no ExecuteMode condition met.</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>0</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>FAIL PORT, Reverse as Catch all fail.</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-1</PortNumber>
        <PortType>Error</PortType>
        <PortDescriptions>PORT FAIL FOR SW ERROR CONDITION</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-2</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PORT FAIL FOR HW ALARM CONDITION</PortDescriptions>
      </ExitPort>
    </ExitPorts>
  </TestLibrary>
</TestLibraryInterfaces>