<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimeForkTestMethod" MetaData="dll=Prime.TestMethods.Fork" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeForkTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="LocationCodeToMatch" descriptions="Configname to selectively execute a set to modify Flow Loop Control.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="IsRegex" descriptions="Value indicating whether the provided \&quot;LocationCodeToMatch\&quot; parameter is a RegEx, or the exact name of the location code to match to.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>True</Choice>
          <Choice>False</Choice>
        </Choices>
        <Default>True</Default>
        <Optional />
      </Parameter>
      <Parameter name="Mode" descriptions="Value that will determine how this FORK will determine its exit port.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Config</Choice>
          <Choice>Parameter</Choice>
        </Choices>
        <AlwaysRequired />
      </Parameter>
    </Parameters>
    <ExitPorts>
      <ExitPort>
        <PortNumber>2-99</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>User defined port.</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>1</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>User defined port or current location matched to user defined "LocationCodeToMatch" parameter.</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>0</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>Current location did not match to user defined "LocationCodeToMatch" parameter.</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-1</PortNumber>
        <PortType>Error</PortType>
        <PortDescriptions>PORT FAIL FOR SW ERROR CONDITION</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-2</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PORT FAIL FOR HW ALARM CONDITION</PortDescriptions>
      </ExitPort>
    </ExitPorts>
  </TestLibrary>
</TestLibraryInterfaces>