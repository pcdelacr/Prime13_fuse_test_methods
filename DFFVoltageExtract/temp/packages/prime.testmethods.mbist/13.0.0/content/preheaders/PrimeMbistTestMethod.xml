      </ExitPort>
      <ExitPort>
        <PortNumber>1</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>Passed</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>2</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>Repairable Arrays</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>3</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>Recovery</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>4</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>Repair and Recovery</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>5</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>Config Error</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>6</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>Missing Corner Case</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>7</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>Failed DTS Monitor</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>8</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>Reset failure</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>9</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>BisrChainCompress Fails</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-1</PortNumber>
        <PortType>Error</PortType>
        <PortDescriptions>PORT FAIL FOR SW ERROR CONDITION</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-2</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PORT FAIL FOR HW ALARM CONDITION</PortDescriptions>
      </ExitPort>
    </ExitPorts>
  </TestLibrary>
</TestLibraryInterfaces>