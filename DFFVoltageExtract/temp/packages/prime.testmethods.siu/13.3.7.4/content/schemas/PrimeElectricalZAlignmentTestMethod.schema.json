{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": [
    "Pins",
    "PinGroups"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "Pins": {
      "type": "array",
      "minItems": 0,
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/Pin"
      },
      "PinGroups": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "$ref": "#/definitions/PinGroup"
        }
      }
    }
  },
  "definitions": {
    "Pin": {
      "type": "object",
      "required": [
        "Channel",
        "Name"
      ],
      "properties": {
        "Channel": {
          "$ref": "#/definitions/PositiveNumber"
        },
        "Name": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "OpensMask": {
          "type": "boolean"
        },
        "ShortsMask": {
          "type": "boolean"
        }
      }
    },
    "PinGroup": {
      "type": "object",
      "required": ["Name", "ShortsLimit", "OpensLimit"],
      "properties": {
        "Name": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "ShortsLimit": {
          "type": "number"
        },
        "OpensLimit": {
          "type": "number"
        }
      }
    },
    "PositiveNumber": {
      "type": "number",
      "minimum": 0
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    }
  }
}
