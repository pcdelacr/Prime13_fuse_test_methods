<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="16.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<Target Name="CopyPrimeReleaseSettingsFile" BeforeTargets="_CollectTargetFrameworkForTelemetry"  Condition="Exists('$(SolutionDir)UserCode.props')">
		<Copy SourceFiles="$(MSBuildThisFileDirectory)/Prime.Release.Settings.props"
		      DestinationFolder="$(SolutionDir)"
		      SkipUnchangedFiles="true"
		      ContinueOnError="true"/>
	</Target>
</Project>
