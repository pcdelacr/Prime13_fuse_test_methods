<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimeHvqkTestMethod" MetaData="dll=Prime.TestMethods.Hvqk" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeHvqkTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="VoltageStepConfigFile" descriptions="The directory of the HvqkConfigJson file.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>File</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="Patlist" descriptions="The Patlist to execute.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>Plist</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="TimingsTc" descriptions="TimingsTc for plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>TimingCondition</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="LevelsTc" descriptions="LevelsTc for plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>LevelsCondition</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="ApplyEndSequence" descriptions="The ApplyEndSequence at the end of the test.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>ENABLED</Choice>
          <Choice>DISABLED</Choice>
        </Choices>
        <Default>DISABLED</Default>
        <Optional />
      </Parameter>
      <Parameter name="PowerDownLevel" descriptions="Custom PowerDown Level for post execution flow.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>LevelsCondition</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="PowerUpLevel" descriptions="Custom PowerUp Level for post execution flow.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>LevelsCondition</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="AlarmHandleDelay" descriptions="Alarm Handle Delay time in millisecond.">
        <Type>
          <Tester>Integer</Tester>
          <TestProgram>Integer</TestProgram>
        </Type>
        <Default>0</Default>
        <Optional />
      </Parameter>
      <Parameter name="DtsConfigurationName" descriptions="Configuration in case DTS processing is wanted.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="MaskPins" descriptions="Comma separated pins for mask.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
    </Parameters>
    <ExitPorts>
      <ExitPort>
        <PortNumber>3</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PLIST EXECUTION FAILED ON USER CONFIGURED VMAX</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>2</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PLIST EXECUTION FAILED ON LOWEST VOLTAGE</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>1</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PASS PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>0</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>FAIL PORT ON DTS FAILED BUT STRESS PASS</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-1</PortNumber>
        <PortType>Error</PortType>
        <PortDescriptions>PORT FAIL FOR SW ERROR CONDITION</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-2</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PORT FAIL FOR HW ALARM CONDITION</PortDescriptions>
      </ExitPort>
    </ExitPorts>
  </TestLibrary>
</TestLibraryInterfaces>