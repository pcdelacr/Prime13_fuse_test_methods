          <Tester>String</Tester>
          <TestProgram>File</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="FuseNamespace" descriptions="Fuse namespace to be used to create the VirtualFuseHandler for FuseManager service.">
