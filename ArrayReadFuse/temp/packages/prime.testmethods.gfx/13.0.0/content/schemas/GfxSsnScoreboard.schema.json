{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "EidMapping": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "PatternName": {
            "type": "string"
          },
          "CTVEidMappingOrder": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}