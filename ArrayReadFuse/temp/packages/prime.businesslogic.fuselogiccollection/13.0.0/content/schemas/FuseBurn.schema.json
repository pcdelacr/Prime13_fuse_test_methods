{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": [ "Configurations" ],
  "properties": {
	"$schema": {
      "type": "string",
      "minLenght": 1
    },
    "Configurations": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Configuration"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Configuration": {
      "type": "object",
      "required": [ "Name", "Registers", "BurnPatternConfig" ],
      "properties": {
        "Name": {
          "type": "string",
          "minLength": 1,
          "uniqueItems": true
        },
        "Registers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Registers"
          }
        },
        "DatalogFormat": {
          "type": "string",
          "enum": [ "RLE", "DEFLATE", "BINARY" ]
        },
        "BurnPatternConfig": {
          "type": "object",
          "items": {
            "$ref": "#/definitions/BurnPatternConfig"
          }
        }
      },
      "additionalProperties": false
    },
    "Registers": {
      "type": "object",
      "required": [ "Name", "DataLabel", "DataLabelOffset" ],
      "properties": {
        "Name": {
          "type": "string",
          "minLength": 1,
          "uniqueItems": true
        },
        "DataLabel": {
          "type": "string",
          "minLength": 1
        },
        "DataLabelOffset": {
          "type": "integer",
          "minLength": 1,
          "minimum": 0
        },
        "FuseGroupsToHide": {
          "type": "string",
          "minLength": 1
        },
        "Masks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Masks"
          }
        },
        "SSPEC": {
          "type": "array",
          "maxItems": 1,
          "items": {
            "$ref": "#/definitions/SSPEC"
          }
        }
      },
      "additionalProperties": false
    },
    "Masks": {
      "type": "object",
      "required": [ "Name", "FuseGroup", "Value" ],
      "properties": {
        "Name": {
          "type": "string",
          "minLength": 1,
          "uniqueItems": true
        },
        "FuseGroup": {
          "type": "string",
          "minLength": 1
        },
        "Value": {
          "type": "string",
          "pattern": "^[01sm]*$",
          "minLength": 1
        },
        "BurnRange": {
          "type": "string",
          "pattern": "^[0-9-,]*$",
          "minLength": 1
        },
        "Dynamic": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Dynamic"
          }
        }
      },
      "additionalProperties": false
    },
    "SSPEC": {
      "type": "object",
      "minItems": 1,
      "maxItems": 1,
      "required": [ "Enable" ],
      "properties": {
        "Enable": {
          "type": "boolean"
        },
        "BurnRange": {
          "type": "string",
          "pattern": "^[0-9-,]*$",
          "minLength": 1
        },
        "Dynamic": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Dynamic"
          }
        }
      },
      "additionalProperties": false
    },
    "Dynamic": {
      "type": "object",
      "required": [ "FuseGroup" ],
      "oneOf": [
        {
          "description": "If uservar is present, sharedstorage and dff field cant be present.",
          "required": [ "uservar" ],
          "not": {
            "required": [ "sharedstorage", "DFF" ]
          }
        },
        {
          "description": "If sharedstorage is present, uservar and dff field cant be present.",
          "required": [ "sharedstorage" ],
          "not": {
            "required": [ "uservar", "DFF" ]
          }
        },
        {
          "description": "If DFF is present, uservar and sharedstorage field cant be present.",
          "required": [ "DFF" ],
          "not": {
            "required": [ "uservar", "sharedstorage" ]
          }
        }
      ],
      "properties": {
        "FuseGroup": {
          "type": "string",
          "minLength": 1,
          "uniqueItems": true
        },
        "uservar": {
          "type": "object",
          "items": {
            "$ref": "#/definitions/uservar"
          }
        },
        "sharedstorage": {
          "type": "object",
          "items": {
            "$ref": "#/definitions/sharedstorage"
          }
        },
        "DFF": {
          "type": "object",
          "items": {
            "$ref": "#/definitions/DFF"
          }
        }
      },
      "additionalProperties": false
    },
    "uservar": {
      "type": "object",
      "minItems": 1,
      "maxItems": 1,
      "required": [ "Name" ],
      "properties": {
        "Name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "sharedstorage": {
      "type": "object",
      "minItems": 1,
      "maxItems": 1,
      "required": [ "Name", "Scope" ],
      "properties": {
        "Name": {
          "type": "string",
          "minLength": 1
        },
        "Scope": {
          "type": "string",
          "enum": [ "DUT", "IP", "LOT" ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "DFF": {
      "type": "object",
      "minItems": 1,
      "maxItems": 1,
      "required": [ "Name", "Optype", "DieID" ],
      "properties": {
        "Name": {
          "type": "string",
          "minLength": 1
        },
        "Optype": {
          "type": "string",
          "minLength": 1
        },
        "DieID": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "BurnPatternConfig": {
      "type": "object",
      "minItems": 1,
      "maxItems": 1,
      "required": [ "ReverseString", "Ratio", "PatternsRegEx" ],
      "properties": {
        "ReverseString": {
          "type": "boolean"
        },
        "Ratio": {
          "type": "integer",
          "default": 1,
          "minimum": 1
        },
        "DataBlockSize": {
          "type": "integer",
          "default": 1,
          "minimum": 1
        },
        "GapSize": {
          "type": "integer",
          "default": 0,
          "minimum": 0
        },
        "PatternsRegEx": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}