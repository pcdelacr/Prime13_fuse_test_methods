<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimePUPTestMethod" MetaData="dll=Prime.TestMethods.PUP" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimePUPTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="PupDebugMode" descriptions="Debug mode.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Disabled</Choice>
          <Choice>Enabled</Choice>
        </Choices>
        <Default>Disabled</Default>
        <Optional />
      </Parameter>
      <Parameter name="Mode" descriptions="Operation mode.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Disabled</Choice>
          <Choice>Enabled</Choice>
        </Choices>
        <Default>Disabled</Default>
        <Optional />
      </Parameter>
      <Parameter name="MonitorLoopNum" descriptions="Monitor Loop number.">
        <Type>
          <Tester>Integer</Tester>
          <TestProgram>Integer</TestProgram>
        </Type>
        <Default>1</Default>
        <Optional />
      </Parameter>
      <Parameter name="PatternsFilePath" descriptions="The path of the patterns file.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="TargetedPlistsFilePath" descriptions="The path of the targeted plists file.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>File</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="EFuseUserFormat" descriptions="The current EFuse user format.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="PupMatchMode" descriptions="The desired PUP match mode which defined how the per unit nodes in PUP.json will be matched.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>EfuseOnly</Choice>
          <Choice>VidOnly</Choice>
          <Choice>VidAndEfuseBoth</Choice>
          <Choice>EfuseAndVidOptional</Choice>
        </Choices>
        <Default>EfuseAndVidOptional</Default>
        <Optional />
      </Parameter>
      <Parameter name="ForceExecutionMode" descriptions="The desired PUP execution mode to force and override the pup file definitions.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>None</Choice>
          <Choice>Short</Choice>
          <Choice>Monitor</Choice>
          <Choice>Full</Choice>
        </Choices>
        <Default>None</Default>
        <Optional />
      </Parameter>
      <Parameter name="PluginName" descriptions="Name of the PUP plugin to use.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="PluginInputFile" descriptions="The user input to the plugin.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
