<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimeScoreboardTestMethod" MetaData="dll=Prime.TestMethods.Scoreboard" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeScoreboardTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="Patlist" descriptions="Patlist to execute.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>Plist</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="TimingsTc" descriptions="TimingsTc for plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>TimingCondition</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="LevelsTc" descriptions="LevelsTc for plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>LevelsCondition</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="ApplyEndSequence" descriptions="ApplyEndSequence at the end of the test.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>DISABLED</Choice>
          <Choice>ENABLED</Choice>
        </Choices>
        <Default>DISABLED</Default>
        <Optional />
      </Parameter>
      <Parameter name="PrePlist" descriptions=" PrePlist callback to plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="MaskPins" descriptions="Comma separated pins for mask.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="CtvCapturePins" descriptions="Comma separated pins for CTV capture.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="CtvCapturePerCycleMode" descriptions="CTV capture mode. If DISABLED (default), CTV capture will be per pin. If ENABLED it will be per cycle.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>DISABLED</Choice>
          <Choice>ENABLED</Choice>
        </Choices>
        <Default>DISABLED</Default>
        <Optional />
      </Parameter>
      <Parameter name="PatternNameCounterIndexes" descriptions="The name of the Pattern Counter Indexes.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="MaxFailsNum" descriptions="The maximum fails number.">
        <Type>
          <Tester>Integer</Tester>
          <TestProgram>Integer</TestProgram>
        </Type>
        <Default>1</Default>
        <Optional />
      </Parameter>
      <Parameter name="BaseNumbers" descriptions="Comma Separated string of base numbers.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
    </Parameters>
    <ExitPorts>
