<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup>
        <PreHeaders Include="$(MSBuildThisFileDirectory)..\content\preheaders\**\*.xml"/>
    </ItemGroup>
  <Target Name="CopyPreHeadersToOutDir" AfterTargets="Build">
    <Copy 
            SourceFiles="@(PreHeaders)" 
            DestinationFiles="@(PreHeaders->'$(OutDir)%(RecursiveDir)%(Filename)%(Extension)')"
            SkipUnchangedFiles="true"
		        ContinueOnError="true"/>
  </Target>
</Project>