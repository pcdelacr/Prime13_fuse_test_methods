        <member name="T:Prime.PowerPremonitionResponseService.IPowerPremonitionResponseService">
            <summary>
            This Service implements the thermal control algorithm named Power Premonition Response. The Interface includes methods for proper initialization and execution of it.
            </summary>
            <remarks>
            <para>This service depends on:</para>
            <list type="bullet">
            <item><see cref="N:Prime.ConsoleService"/></item>
            <item><see cref="N:Prime.DatalogService"/></item>
            <item><see cref="N:Prime.PupService"/></item>
            <item><see cref="N:Prime.SharedStorageService"/></item>
            <item><see cref="N:Prime.ThermalService"/></item>
            <item><see cref="N:Prime.UserVarService"/></item>
            </list>
            </remarks>
        </member>
        <member name="M:Prime.PowerPremonitionResponseService.IPowerPremonitionResponseService.InitializeLot(System.Collections.Generic.List{System.String},System.Boolean,System.Boolean,Prime.SessionService.ISessionContextProviderContainer)">
            <summary>
            Initialized the Power Premonition Response service configuration structure for Lot parameters .
            </summary>
            /// <param name="pinNames">list of the tdau sensors to use.</param>
            <param name="isDtc">boolean to select between DTC or TCC.</param>
            <param name="enableSerialCaptureDts">flag to enable DTS profile to PPR PUDL log.</param>
            <param name="sessionContext">The session context of this operation.</param>
            <returns>Returns the configuration object to be populated.</returns>
            <remarks>
            <example>
            <code>
            var useDtc = this.ThermalController == ControllerType.DTC;
            var isDtsProfileEnabled = this.SerialCaptureDtsProfile == SerialCaptureProfileState.ENABLED;
            var tdauPins = Base.ServiceStore&lt;IThermalService&gt;.Service.GetAllTdauPinNames(this.SessionContext);
            var configuration = Base.ServiceStore&lt;IPowerPremonitionResponseService&gt;.Service.InitializeLot(tdauPins, useDtc, isDtsProfileEnabled, this.SessionContext);
            </code>
            </example>
            <para>This function depends on:</para>
            <list type="bullet">
            <item><see cref="N:Prime.SharedStorageService"/>.</item>
            </list>
            </remarks>
        </member>
        <member name="M:Prime.PowerPremonitionResponseService.IPowerPremonitionResponseService.InitializeDevice(Prime.SessionService.ISessionContextProviderContainer)">
            <summary>
            Initialized the Power Premonition Response service configuration structure for device specific parameters.
            </summary>
            <param name="sessionContext">The session context of this operation.</param>
            <returns>Returns the configuration object to be populated.</returns>
            <remarks>
            <example>
            <code>
            var configuration = Base.ServiceStore&lt;IPowerPremonitionResponseService&gt;.Service.InitializeDevice(this.SessionContext);
               this.SetInitialConfiguration(configuration);
               this.AddActionsToConfiguration(configuration);
            configuration.SaveToSharedStorage(this.SessionContext);
            </code>
            </example>
            <para>This function depends on:</para>
            <list type="bullet">
            <item><see cref="N:Prime.SharedStorageService"/>.</item>
            </list>
            </remarks>
        </member>
        <member name="M:Prime.PowerPremonitionResponseService.IPowerPremonitionResponseService.PreExecute(System.String,Prime.SessionService.ISessionContextProviderContainer)">
            <summary>
            PPR logic/algorithms that should be executed before every instance to ensure the thermal control methodology is applied.
            </summary>
            <param name="currentInstanceName">currentInstanceName.</param>
            <param name="sessionContext">The session context of this operation.</param>
            <remarks>
            <para>This function depends on:</para>
            <list type="bullet">
            <item><see cref="N:Prime.SharedStorageService"/>.</item>
            <item><see cref="N:Prime.ThermalService"/>.</item>
            <item><see cref="N:Prime.ConsoleService"/>.</item>
            <item><see cref="N:Prime.PupService"/>.</item>
            <item><see cref="N:Prime.UserVarService"/>.</item>
            <item><see cref="M:Prime.PowerPremonitionResponseService.IPowerPremonitionResponseService.InitializeLot(System.Collections.Generic.List{System.String},System.Boolean,System.Boolean,Prime.SessionService.ISessionContextProviderContainer)"/>.</item>
            <item><see cref="M:Prime.PowerPremonitionResponseService.IPowerPremonitionResponseService.InitializeDevice(Prime.SessionService.ISessionContextProviderContainer)"/>.</item>
            </list>
            </remarks>
        </member>
