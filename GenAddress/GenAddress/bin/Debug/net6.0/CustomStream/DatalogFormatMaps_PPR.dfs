Version 0.1.0;
FormatMap PPREventFormatMap  #Conventional datalog format
{
	Type PPR; #Name of the stream in your DatalogTypeDef.xml
	Event PPREvent;  #Name of the event in your DatalogTypeDef.xml
	Format PPREventFormat; #Name of the format (used in your Format.dfs file)
}
FormatMap PPREndOfTransmissionFormatMap
{
	Type PPR;
	Event HMI_EndOfTransmission;
	Format PPREndOfTransmissionFormat;
}