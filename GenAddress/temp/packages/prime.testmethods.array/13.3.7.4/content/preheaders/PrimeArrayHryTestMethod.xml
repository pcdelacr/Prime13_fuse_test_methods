          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="MaskPins" descriptions="Gets or sets comma separated pins for mask.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="RawStringForwardingMode" descriptions="Gets or sets the Raw String forwarding mode.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>PRE</Choice>
          <Choice>POST</Choice>
        </Choices>
        <Default>PRE</Default>
        <Optional />
      </Parameter>
      <Parameter name="SharedStorageKey" descriptions="Gets or sets the Key to be used with Raw STring Forwarding mode. If empty the mode is disabled.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
