Version 0.1.0;
FormatMap TFileEventFormatMap  #Conventional datalog format
{
	Type TFile; #Name of the stream in your DatalogTypeDef.xml
	Event TFileEvent;  #Name of the event in your DatalogTypeDef.xml
	Format TFileEventFormat; #Name of the format (used in your Format.dfs file)
}
FormatMap TFileEndOfTransmissionFormatMap
{
	Type TFile;
	Event HMI_EndOfTransmission;
	Format TFileEndOfTransmissionFormat;
}