<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimeDcLeakageTestMethod" MetaData="dll=Prime.TestMethods.Dc" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeDcLeakageTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="TimingsTc" descriptions="Gets or sets TimingsTc for plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>TimingCondition</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="LevelsTc" descriptions="Gets or sets LevelsTc to plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>LevelsCondition</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="TestType" descriptions="Gets or sets the leakage test to execute (VCC for Low Leakage, VSS for High, Both for both).">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Both</Choice>
          <Choice>VCC</Choice>
          <Choice>VSS</Choice>
        </Choices>
        <Default>Both</Default>
        <Optional />
      </Parameter>
      <Parameter name="LkgHiPlist" descriptions="Gets or sets Patlist for leakage low test.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>Plist</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="LkgHiLevels" descriptions="Gets or sets LevelsTc to plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>LevelsCondition</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="LkgLoPlist" descriptions="Gets or sets Patlist for leakage low test.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>Plist</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="LkgLoLevels" descriptions="Gets or sets LevelsTc to plist execution.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>LevelsCondition</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="ConfigurationFile" descriptions="Gets or sets the json file which contains DcLeakage configurations.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>File</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="Configuration" descriptions="Gets or sets ConfigurationSet name from Json to be used during testing.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
