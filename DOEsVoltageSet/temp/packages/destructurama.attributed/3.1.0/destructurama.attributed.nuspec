<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Destructurama.Attributed</id>
    <version>3.1.0</version>
    <authors>Serilog Contributors</authors>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <icon>icon.png</icon>
    <projectUrl>https://github.com/destructurama</projectUrl>
    <description>Use attributes to control how complex types are logged to Serilog.</description>
    <tags>serilog attributed</tags>
    <repository type="git" url="https://github.com/destructurama/attributed.git" commit="81cdcea623ffcd37a91f72a835c1a216b5a3b08f" />
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Serilog" version="[2.10.0, 4.0.0)" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>