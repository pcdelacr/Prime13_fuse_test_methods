{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": ["XIUs"],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "XIUs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/XIU"
      }
    }
  },
  "definitions": {
    "XIU": {
      "type": "object",
      "required": [
        "Name",
        "Pins",
        "PinGroups"
      ],
      "properties": {
        "Name": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "Pins": {
          "type": "array",
          "minItems": 0,
          "uniqueItems": true,
          "items": {
            "$ref": "#/definitions/Pins"
          },
          "PinGroups": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/definitions/PinGroup"
            }
          }
        }
      }
    },
    "Pins": {
      "type": "object",
      "required": [
        "Channel",
        "Name",
        "BaseReading",
        "ContactResistanceLimit"
      ],
      "properties": {
        "Channel": {
          "$ref": "#/definitions/PositiveNumber"
        },
        "Name": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "BaseReading": {
          "type": "number"
        },
        "ContactResistanceLimit": {
          "type": "number"
        },
        "OpensMask": {
          "type": "boolean"
        },
        "ShortsMask": {
          "type": "boolean"
        },
        "ContactResistanceMask": {
          "type": "boolean"
        }
      }
    },
    "PinGroup": {
      "type": "object",
      "required": ["Name", "ShortsLimit", "OpensLimit"],
      "properties": {
        "Name": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "ShortsLimit": {
          "type": "number"
        },
        "OpensLimit": {
          "type": "number"
        }
      }
    },
    "PositiveNumber": {
      "type": "number",
      "minimum": 0
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    }
  }
}