{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": [ "PacketConfigurations" ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "PacketConfigurations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/PacketConfiguration"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "PacketConfiguration": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "Name": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "DataPins": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" },
          "minItems": 1,
          "uniqueItems": true
        },
        "IdPins": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" },
          "minItems": 1,
          "uniqueItems": true
        },
        "ValidPins": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" },
          "minItems": 1,
          "uniqueItems": true
        },
        "ValidValues": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" },
          "minItems": 1,
          "uniqueItems": true
        },
        "PacketSize": {
          "type": "integer",
          "minimum": 1
        },
        "ErrorWhenPacketSizeMismatch": {
          "type": "boolean"
        }
      },
      "required": [
        "Name",
        "DataPins",
        "IdPins",
        "ValidPins",
        "ValidValues",
        "PacketSize",
        "ErrorWhenPacketSizeMismatch"
      ],
      "additionalProperties": false
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    }
  }
}
