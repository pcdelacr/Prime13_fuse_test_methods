<?xml version="1.0" encoding="utf-8"?>
<TestLibraryInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://vtsm.intel.com/2009/TestLibraryInterfaces file:///C:/Intel/hdmt/hdmtOS_3.9.0.1_Release/TOSRelease/bin/release/TestLibraryInterfaces.xsd" xmlns="http://vtsm.intel.com/2009/TestLibraryInterfaces">
  <TestLibrary name="PrimeTestInstance">
    <TestClass name="PrimeThermalRampTestMethod" MetaData="dll=Prime.TestMethods.Thermal" />
    <Imports>
      <FileName>TestMethodBase.xml</FileName>
      <FileName>PrimeThermalRampTestMethodCommonParams.xml</FileName>
    </Imports>
    <PublicBases>
      <BaseName>TestMethodBase</BaseName>
    </PublicBases>
    <Parameters>
      <Parameter name="PinNames" descriptions="TDAU pins names to check.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="LogPinToken" descriptions="Datalog selectors to use for each Pin when printing to ituff.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="RampMode" descriptions="Ramp mode. changes print format.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>Presoak</Choice>
          <Choice>Normal</Choice>
          <Choice>Soak</Choice>
          <Choice>Fact</Choice>
        </Choices>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="Patlist" descriptions="optional pattern run during soak.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>Plist</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="LevelsTc" descriptions="levels Test Condition used with pattern.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>LevelsCondition</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="ApplyEndSequence" descriptions="The applySequence for the end of the test.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Choices>
          <Choice>DISABLED</Choice>
          <Choice>ENABLED</Choice>
        </Choices>
        <Default>DISABLED</Default>
        <Optional />
      </Parameter>
      <Parameter name="TimingsTc" descriptions="Timing test Condition that used with the pattern.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>TimingCondition</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="PrePlist" descriptions="PrePlist callback to plist execution">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="MaskPins" descriptions="Pins to mask.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <Default />
        <Optional />
      </Parameter>
      <Parameter name="SetPoints" descriptions="Set points, use one for all or one per pin.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="UpperTolerance" descriptions="List of tolerance values to calculate the high limits of the measurement.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="LowerTolerance" descriptions="List of tolerance values to calculate the low limits of the measurement.">
        <Type>
          <Tester>String</Tester>
          <TestProgram>String</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
      <Parameter name="IntegrityHighLimit" descriptions="High temperature limit of a measurement integrity check.">
        <Type>
          <Tester>Integer</Tester>
          <TestProgram>Integer</TestProgram>
        </Type>
        <Default>200</Default>
        <Optional />
      </Parameter>
      <Parameter name="IntegrityLowLimit" descriptions="Low temperature limit of a measurement integrity check.">
        <Type>
          <Tester>Integer</Tester>
          <TestProgram>Integer</TestProgram>
        </Type>
        <Default>130</Default>
        <Optional />
      </Parameter>
      <Parameter name="Timeout" descriptions="Timeout in miliseconds">
        <Type>
          <Tester>Integer</Tester>
          <TestProgram>Integer</TestProgram>
        </Type>
        <AlwaysRequired />
      </Parameter>
    </Parameters>
    <ExitPorts>
      <ExitPort>
        <PortNumber>5</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>FAIL PORT - INTEGRITY HiGH LIMIT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>4</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>FAIL PORT - INTEGRITY LOW LIMIT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>3</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>FAIL PORT - THERMAL HIGH LIMIT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>2</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>FAIL PORT - THERMAL LOW LIMIT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>1</PortNumber>
        <PortType>Pass</PortType>
        <PortDescriptions>PASS PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>0</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>FAIL PORT</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-1</PortNumber>
        <PortType>Error</PortType>
        <PortDescriptions>PORT FAIL FOR SW ERROR CONDITION</PortDescriptions>
      </ExitPort>
      <ExitPort>
        <PortNumber>-2</PortNumber>
        <PortType>Fail</PortType>
        <PortDescriptions>PORT FAIL FOR HW ALARM CONDITION</PortDescriptions>
      </ExitPort>
    </ExitPorts>
  </TestLibrary>
</TestLibraryInterfaces>