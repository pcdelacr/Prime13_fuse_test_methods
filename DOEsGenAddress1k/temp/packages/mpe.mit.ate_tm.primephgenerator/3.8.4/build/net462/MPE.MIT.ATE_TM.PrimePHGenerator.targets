<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <UsingTask TaskName="Prime.MsBuild.Tasks.BuildPhFilesTask" AssemblyFile="..\..\prime_tasks\PrimeMsbuildTasks.dll" />
  <Target Name="BeforeBuild">
    <BuildPhFilesTask OutDir="$(OutDir)" OutputDirRelativePath="$(PreHeaderLocationRelativePath)"/>
  </Target>
</Project>