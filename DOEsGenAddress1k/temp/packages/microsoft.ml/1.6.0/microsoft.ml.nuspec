<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Microsoft.ML</id>
    <version>1.6.0</version>
    <authors>Microsoft</authors>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="file">LICENSE</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <icon>mlnetlogo.png</icon>
    <projectUrl>https://dot.net/ml</projectUrl>
    <description>ML.NET is a cross-platform open-source machine learning framework which makes machine learning accessible to .NET developers.</description>
    <releaseNotes>https://aka.ms/mlnetreleasenotes</releaseNotes>
    <copyright>© Microsoft Corporation. All rights reserved.</copyright>
    <tags>ML.NET ML Machine Learning</tags>
    <serviceable>true</serviceable>
    <repository type="git" url="https://github.com/dotnet/machinelearning" commit="eb9cee6e5345b27f762119d060f62514d0163f7f" />
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.ML.CpuMath" version="1.6.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.ML.DataView" version="1.6.0" exclude="Build,Analyzers" />
        <dependency id="Newtonsoft.Json" version="10.0.3" include="All" />
        <dependency id="System.CodeDom" version="4.4.0" include="All" />
        <dependency id="System.Collections.Immutable" version="1.5.0" include="All" />
        <dependency id="System.Memory" version="4.5.3" include="All" />
        <dependency id="System.Reflection.Emit.Lightweight" version="4.3.0" include="All" />
        <dependency id="System.Threading.Channels" version="4.7.1" include="All" />
      </group>
    </dependencies>
  </metadata>
</package>